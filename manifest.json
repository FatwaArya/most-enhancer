{
  "manifest_version": 3,
  "name": "MOST Enhancer",
  "version": "2.0.0",
  "description": "Order book overlays + Price Vol Freq analysis for Mandiri Sekuritas / Growin. Multi-panel aware.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.most.co.id/*",
    "https://*.mandirisekuritas.co.id/*",
    "https://*.growin.id/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.most.co.id/*",
        "https://*.mandirisekuritas.co.id/*",
        "https://*.growin.id/*"
      ],
      "js": ["metrics.js", "alerts.js", "overlay.js", "control-panel.js", "pvf-injector.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
